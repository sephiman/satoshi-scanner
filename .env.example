# Telegram alerts
TELEGRAM_TOKEN=123456:ABCDEF...
TELEGRAM_CHAT_ID=12345678

# Scanner behaviour
# CHECK_MODE: "live" (default, hits Blockstream API per address)
#             "database" (looks up local Postgres; only verifies hits live)
CHECK_MODE=live
SCAN_INTERVAL=1.0
LOG_LEVEL=INFO

# Postgres (required when CHECK_MODE=database)
POSTGRES_HOST=postgresdb
POSTGRES_PORT=5432
POSTGRES_USER=scanner
POSTGRES_PASSWORD=changeme
POSTGRES_DB=satoshi_scanner

# Optional override for the funded-addresses dump
# FUNDED_ADDRESSES_URL=http://addresses.loyce.club/Bitcoin_addresses_LATEST.txt.gz
