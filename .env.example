# Telegram alerts
TELEGRAM_TOKEN=123456:ABCDEF...
TELEGRAM_CHAT_ID=12345678

# Scanner behaviour
# CHECK_MODE: "live" (default, hits Blockstream API per address)
#             "database" (looks up local Postgres; only verifies hits live)
CHECK_MODE=live
SCAN_INTERVAL=1.0
LOG_LEVEL=INFO

# Address forms derived per private key. Any comma-separated subset of:
#   p2pkh_c (compressed legacy 1...), p2pkh_u (uncompressed legacy 1...),
#   p2sh_p2wpkh (nested segwit 3...), p2wpkh (native segwit bc1q...)
# In live mode each type costs one Blockstream call per key, so trim this
# list (or raise SCAN_INTERVAL) if you hit rate limits.
ADDRESS_TYPES=p2pkh_c,p2pkh_u,p2sh_p2wpkh,p2wpkh

# Keys generated per iteration in database mode (live mode always uses 1).
BATCH_SIZE=1000

# Where found wallets are appended as JSON lines (kept on the scanner_data
# volume) before any Telegram alert is attempted.
FOUND_WALLETS_FILE=data/found_wallets.jsonl

# Port where /metrics is exposed for Prometheus scraping.
METRICS_PORT=8000

# Postgres (required when CHECK_MODE=database)
POSTGRES_HOST=postgresdb
POSTGRES_PORT=5432
POSTGRES_USER=scanner
POSTGRES_PASSWORD=changeme
POSTGRES_DB=satoshi_scanner

# Re-download the funded-address dump when it is older than this many days.
# 0 (default) disables automatic refresh.
DUMP_MAX_AGE_DAYS=0

# Optional override for the funded-addresses dump
# FUNDED_ADDRESSES_URL=http://addresses.loyce.club/Bitcoin_addresses_LATEST.txt.gz
